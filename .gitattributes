# Normalize all text files to LF in the repo. Working tree on Windows can use CRLF
# but the Dockerfiles, shell scripts, and Python tooling expect LF.
* text=auto eol=lf

# Force LF for these regardless of platform settings
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.sh    text eol=lf

# Binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   text eol=lf
*.pdf   binary
