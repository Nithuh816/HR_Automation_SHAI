# ============================================================
# HR_Automation_SHAI — environment template
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- Core ---
APP_ENV=development              # development | staging | production
APP_SECRET_KEY=change-me-to-a-long-random-string
PII_ENC_KEY=                     # 32-byte base64 Fernet key. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LOG_LEVEL=INFO

# --- Database (Postgres) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hr_automation
POSTGRES_USER=hr
POSTGRES_PASSWORD=hr_dev_password
DATABASE_URL=postgresql+psycopg://hr:hr_dev_password@localhost:5432/hr_automation

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Object storage (S3-compatible: MinIO / Cloudflare R2 / AWS S3) ---
STORAGE_BACKEND=minio            # local | minio | r2 | s3
STORAGE_BUCKET=hr-documents
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_admin_password
S3_PRESIGN_TTL_SECONDS=300

# --- Microsoft 365 / Entra ID (SSO + Teams) ---
MS_TENANT_ID=                    # GUID from Entra admin
MS_CLIENT_ID=                    # App registration client ID
MS_CLIENT_SECRET=                # App registration client secret
MS_REDIRECT_URI=http://localhost:5173/auth/callback
MS_SCOPES=openid profile email User.Read OnlineMeetings.ReadWrite Calendars.ReadWrite.Shared

# --- GreytHR ---
GREYTHR_BASE_URL=                # https://api.greythr.com/...
GREYTHR_API_KEY=
GREYTHR_TENANT=                  # SHAI's GreytHR subdomain or tenant id

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=           # for webhook signature verification

# --- Email ---
EMAIL_PROVIDER=smtp              # smtp | resend
EMAIL_FROM=hr-noreply@shaihealth.example
# SMTP (also used by Microsoft 365 SMTP relay)
SMTP_HOST=localhost
SMTP_PORT=1025                   # MailHog in dev
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
# Resend (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# --- Frontend (Vite reads VITE_* only) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_MS_TENANT_ID=
VITE_MS_CLIENT_ID=
VITE_MS_REDIRECT_URI=http://localhost:5173/auth/callback

# --- Magic links (candidate portal) ---
MAGIC_LINK_HMAC_KEY=change-me-to-a-different-long-random-string
MAGIC_LINK_BASE_URL=http://localhost:5173/c

# --- Compose service hostnames (auto-overridden in docker-compose.yml) ---
# When running inside docker compose, the api/web services use service names
# (postgres, redis, minio, mailhog) instead of localhost.
